# Site
NEXT_PUBLIC_SITE_URL=https://app.brendiapro.hr
NEXT_PUBLIC_APP_URL=https://app.brendiapro.hr

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Monri Payment Gateway
MONRI_MERCHANT_KEY=your_merchant_key
MONRI_AUTHENTICITY_TOKEN=your_40_char_authenticity_token
MONRI_ENVIRONMENT=test  # "test" or "production"

# Mux Video
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_SIGNING_KEY=your-mux-signing-key
MUX_SIGNING_KEY_ID=your-mux-signing-key-id

# Email (Resend)
RESEND_API_KEY=re_...
ADMIN_EMAIL=info@brendiapro.hr

# Mobile App API Key (optional)
MOBILE_API_KEY=your-uuid-api-key
